# LocalFlow configuration template.
#
# Copy this file to ".env" and fill in the values you want.
# `.env` is git-ignored — never commit it.
#
# Precedence (highest wins):
#   1. CLI flag (e.g. --llm-model gpt-4o)
#   2. Shell environment variable (set in PowerShell / your terminal)
#   3. This .env file
#   4. Code default

# ---------------------------------------------------------------- OpenAI (default)

# Required for --planner llm --llm-provider openai (which is now the default).
OPENAI_API_KEY=

# Optional. Default is "gpt-5". If your account doesn't have access, override:
#   common fallbacks: gpt-4o, gpt-4o-mini, o4-mini
# LOCALFLOW_OPENAI_MODEL=gpt-4o

# Optional. For OpenAI reasoning models (o-series, possibly gpt-5):
#   "low" | "medium" | "high"
# LOCALFLOW_OPENAI_REASONING_EFFORT=medium

# ---------------------------------------------------------------- Anthropic (optional)

# Only needed if you set LOCALFLOW_LLM_PROVIDER=anthropic or pass
# --llm-provider anthropic on the CLI.
# ANTHROPIC_API_KEY=sk-ant-replace-me

# Optional. Default is "claude-opus-4-7".
# LOCALFLOW_LLM_MODEL=claude-opus-4-7

# ---------------------------------------------------------------- LocalFlow defaults

# Default LLM provider when --planner=llm and no --llm-provider is given.
# Values: openai | anthropic
# LOCALFLOW_LLM_PROVIDER=openai

# Where LocalFlow keeps task state (.localflow/runs/<task_id>/...).
# Defaults to "<cwd>/.localflow".
# LOCALFLOW_HOME=C:\Users\13513\Desktop\XIANGMU\localflow\.localflow
