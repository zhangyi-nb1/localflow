#!/usr/bin/env bash
# LocalFlow pre-push gate.
#
# Mirrors what CI does in .github/workflows/ci.yml so a `git push`
# that would have failed CI is stopped on the developer's machine
# instead. Three checks, in order, with a fail-fast bail:
#
#   1. ruff check (lint)            ← matches CI step 5
#   2. ruff format --check          ← matches CI step 6
#   3. pytest --tb=no               ← matches CI step 7
#
# Activation (one-time): from the repo root, run
#
#     git config core.hooksPath .githooks
#
# That points git at this tracked directory; nothing else to do.
# Disable in an emergency with `git push --no-verify`.

set -e

# Locate the Python interpreter — preferring the project venv, falling
# back to the system one so the hook doesn't error in environments
# where the venv has been recreated under a different name.
PY=""
for candidate in .venv/bin/python venv/bin/python python3 python; do
    if [ -x "$candidate" ] || command -v "$candidate" > /dev/null 2>&1; then
        PY="$candidate"
        break
    fi
done

if [ -z "$PY" ]; then
    echo "pre-push: no Python interpreter found (tried .venv/bin/python, venv/bin/python, python3, python)"
    exit 1
fi

# Resolve ruff: prefer venv-local, fall back to project-relative invocation.
RUFF=""
for candidate in .venv/bin/ruff venv/bin/ruff; do
    if [ -x "$candidate" ]; then
        RUFF="$candidate"
        break
    fi
done
if [ -z "$RUFF" ]; then
    RUFF="$PY -m ruff"
fi

# Scopes mirror .github/workflows/ci.yml exactly. The lint step
# intentionally excludes examples/ (those are demonstration skills
# meant to stay readable, not enforced clean); the format step keeps
# examples/ in scope so demos do not drift visually.
echo "─── pre-push check 1/3: ruff lint   (app/ tests/)"
$RUFF check app/ tests/

echo "─── pre-push check 2/3: ruff format check   (app/ tests/ examples/)"
$RUFF format --check app/ tests/ examples/

echo "─── pre-push check 3/3: pytest --tb=no"
$PY -m pytest --tb=no -q

echo ""
echo "✓ pre-push: all checks passed. Pushing."
