# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
build/
dist/
.eggs/

# Virtual environments
.venv/
venv/
env/

# Tooling
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.mypy_cache/
.ruff_cache/

# LocalFlow run artifacts
.localflow/

# Secrets — NEVER commit a real .env. Track .env.example instead.
.env
.env.local
.env.*.local

# MCP client config — has machine-specific absolute paths.
# Track .mcp.json.example instead.
.mcp.json

# IDE
.vscode/
.idea/
*.swp

# OS
.DS_Store
Thumbs.db

# --- LocalFlow project-specific ---

# Privacy: real user data dropped into the project root for testing.
real_data/
real_csv_seed.py

# Test sandbox — generated by sandbox_seed.py, contents are stale and
# can be large. Keep sandbox_seed.py (helpful seed for new contributors)
# but never commit the sandbox/ output itself.
sandbox/
sandbox_*/

# Phase 14 demo: research_pack/workspace/ is regenerated by seed.py
# and contains both seeded files + post-run pack artifacts. Track
# seed.py + workspace_pack.yaml + README.md only.
examples/research_pack/workspace/

# Phase 20 demo workspaces — same regenerate-from-seed pattern.
examples/data_report_pack/workspace/
examples/project_handoff_pack/workspace/

# Phase 36 flagship demo workspace — regenerated by seed.py.
examples/literature_review_pack/workspace/

# Codex / MCP local config — has machine-specific absolute paths
# (same problem as .mcp.json). Keep on disk for the developer's IDE
# but never commit.
.codex/

# Proxy/connection probe scripts — debug-only, contain internal IPs.
# Memory note: "保留在仓库根（不进 git）".
probe_*.py
probe_*.json

# Throwaway smoke-test venvs from wheel build verification
.venv-*/
